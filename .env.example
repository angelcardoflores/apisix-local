# Plantilla de variables de entorno. Copiar a .env y rellenar con los valores reales.
# El .env real NO debe commitearse (está en .gitignore).

# --- Repositorios internos (build de farmameterms / mock-nfv) ---
# Token de acceso al git interno. SECRETO: no commitear el valor real.
GIT_TOKEN=tu-token-de-git
REPO_URL=http://git.inda.es/desa/farmameterms.git
BRANCH=master

NFV_REPO_URL=http://git.inda.es/desa/mock-nfv.git
NFV_BRANCH=master

# --- Credenciales del colegio para NodoFarma (compartidas NFV + REP) ---
# SECRETO: no commitear los valores reales.
COF_CLIENT_ID=tu-client-id
COF_CLIENT_SECRET=tu-client-secret

# --- Scope NFV (fijo) ---
NFV_SCOPE=NodoFarmaVerificacionConCofScope

# --- Scope y application REP (cambian entre entornos pre/pro) ---
REP_SCOPE=TokenScope
REP_APPLICATION=rmepPresentations-pre
